# ─────────────────────────────────────────────────────────────
#  Quran O Itrat Academy — Backend Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/quran_o_itrat

# ── JWT Authentication ────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d
BCRYPT_ROUNDS=12

# ── CORS (production only) ────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Frontend URL (used in email links) ───────────────────────
SITE_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────
#  EMAIL CONFIGURATION (nodemailer)
#  The backend will send admin notifications to ADMIN_EMAIL
#  whenever a contact form or admission form is submitted.
# ─────────────────────────────────────────────────────────────

# Admin notification recipient
ADMIN_EMAIL=admin@quranoitratacademy.com

# "From" display in outgoing emails
FROM_EMAIL="Quran O Itrat Academy" <noreply@quranoitratacademy.com>

# ── Option A: Gmail (recommended for quick setup) ────────────
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate an App Password: Google Account → Security → App Passwords
# 3. Use those credentials below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password

# ── Option B: Custom SMTP / Hostinger / cPanel ───────────────
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=your_email_password

# ── Option C: SendGrid ────────────────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key

# ── Option D: Outlook / Office 365 ───────────────────────────
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your@outlook.com
# SMTP_PASS=your_password
